# ── Security ──────────────────────────────────────────────────────────────
# Optional for dev (auto-generated if empty). For production, generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── CORS ──────────────────────────────────────────────────────────────────
# Comma-separated origins allowed to call the API
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ── MongoDB ───────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=gas_incident_platform

# ── Database (SQLite/Postgres) ────────────────────────────────────────────
DATABASE_URL=sqlite:///./gas_incidents.db

# ── Redis ─────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Connectors ────────────────────────────────────────────────────────────
# Generate separately from SECRET_KEY: python -c "import secrets; print(secrets.token_urlsafe(32))"
CONNECTOR_ENCRYPTION_KEY=
CONNECTOR_SYNC_ENABLED=true

# ── File Upload ───────────────────────────────────────────────────────────
MAX_UPLOAD_SIZE_MB=10
UPLOAD_DIR=./uploads

# ── Seeding ───────────────────────────────────────────────────────────────
# Set to true in production to skip demo user seeding
SKIP_SEED=false
